{
    "name": "@vuegraphx/core",
    "version": "1.0.0",
    "type": "module",
    "description": "The math and graphics engine core for VueGraphX",
    "main": "./dist/vuegraphx-core.umd.cjs",
    "module": "./dist/vuegraphx-core.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/vuegraphx-core.js",
            "require": "./dist/vuegraphx-core.umd.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "vite build"
    },
    "dependencies": {
        "jsxgraph": "^1.8.0",
        "katex": "^0.16.33",
        "mathjs": "^15.1.1",
        "nerdamer": "^1.1.13"
    },
    "devDependencies": {
        "typescript": "^5.4.5",
        "vite": "^5.2.8",
        "vite-plugin-dts": "^3.8.3"
    }
}